# ---------------------------------------------------------------------------
# Supabase — browser/SSR client (@supabase/ssr)
# Used by the app's pages, Server Components, and Server Actions.
# Find these in your Supabase project: Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ---------------------------------------------------------------------------
# Admin allowlist — REQUIRED for admin access.
# Comma-separated list of emails that get the full /dashboard admin app. Anyone
# signing in whose email is NOT listed is treated as a customer or portal user.
# Admin status lives ONLY here (never in the database), so customers can never
# promote themselves. If this is empty, NO ONE can reach the admin dashboard.
# ---------------------------------------------------------------------------
ADMIN_EMAILS=admin@tdstudiosny.com

# ---------------------------------------------------------------------------
# Public site URL — used as metadataBase for absolute OG/manifest URLs.
# In Vercel this can be omitted (VERCEL_URL is used); set it for a custom domain.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# ---------------------------------------------------------------------------
# Supabase — server SDK (@supabase/server) for the API route handlers
# Copy the real values from the Supabase dashboard's "Connect" dialog.
# These use the new API key system (sb_publishable_… / sb_secret_…).
# The SECRET key bypasses RLS — keep it server-only, NEVER commit it.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
# Used to verify user JWTs (asymmetric signing keys):
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# ---------------------------------------------------------------------------
# Resend — transactional email (emailing invoices + portal invites)
# Server-only. The app degrades gracefully when these are unset: invoice email
# is disabled and portal invites fall back to a one-time temp password.
# RESEND_FROM_EMAIL must be an address on a domain verified in Resend.
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=TD Studios <invoices@invoices.tdstudiosny.com>
