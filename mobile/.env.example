EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL of the deployed web app. Lets the app open the authoritative
# (pdf-lib) invoice PDF from /api/invoices/[id]/pdf. Optional — without it the
# PDF viewer falls back to a locally rendered HTML recreation.
EXPO_PUBLIC_API_BASE_URL=https://your-web-app.example.com
